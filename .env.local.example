# ============================================================
# GameShop v5 — Environment Variables
# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริงจาก Supabase Dashboard
# ============================================================

# Supabase — ดูได้ที่: https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Resend (สำหรับส่งอีเมล forgot-password)
# สมัครฟรีได้ที่ https://resend.com
RESEND_API_KEY=re_your_api_key_here

# URL ของแอป (ใช้ใน reset-password email link)
# local: http://localhost:3000 | production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
